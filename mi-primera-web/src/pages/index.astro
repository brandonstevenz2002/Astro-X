---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mi Primera Web con Astro">
	<!-- HERO -->
	<section class="hero">
		<h1>Bienvenido a Mi Página</h1>
		<p>Construida con Astro, paso a paso.</p>
		<a href="#sobre-mi" class="btn">Descúbreme</a>
	</section>

	<!-- SOBRE MÍ -->
	<section id="sobre-mi" class="sobre-mi">
		<div class="sobre-mi_inner">
			<div class="sobre-mi__avatar">
				<div class="avatar-placeholder">👤</div>
			</div>
			<div class="sobre-mi__content">
				<h2>Sobre mí</h2>
				<p>
					Soy un desarrollador apasinado por crear experiencias web
					únicas y de alto rendimiento.
				</p>
				<p>
					Cuando no estoy programando, estoy explorando nuevas
					tecnologías o tomando café ☕.
				</p>
				<div class="skills">
					<span class="skill-tag">Astro</span>
					<span class="skill-tag">React</span>
					<span class="skill-tag">Typescript</span>
					<span class="skill-tag">Node.js</span>
					<span class="skill-tag">CSS</span>
					<span class="skill-tag">Git</span>
				</div>
			</div>
		</div>
	</section>

	<!-- PORTFOLIO -->
	<section id="portfolio" class="portfolio">
		<h2>Portfolio</h2>
		<p class="section-subtitle">Algunos de mis proyectos recientes</p>
		<div class="portfolio__grid">
			<article class="portfolio-card">
				<div class="portfolio-card__img">🌐</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Alpha</h3>
					<p>
						Aplicación web construida con Astro y React. Optimizada
						para velocidad y SEO.
					</p>
					<div class="portfolio-card__tags">
						<span>Astro</span><span>React</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
			<article class="portfolio-card">
				<div class="portfolio-card__img">⚡</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Beta</h3>
					<p>
						Dashborad interactivo con visualización de datos en
						tiempo real.
					</p>
					<div class="portfolio-card__tags">
						<span>TypeScript</span><span>Node.js</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
			<article class="portfolio-card">
				<div class="portfolio-card__img">🚀</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Gamma</h3>
					<p>
						E-commerce moderno con integración de pagos y gestión de
						inventario.
					</p>
					<div class="portfolio-card__tags">
						<span>CSS</span><span>Git</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
			<article class="portfolio-card">
				<div class="portfolio-card__img">🎨</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Delta</h3>
					<p>
						Plataforma de diseño colaborativo con soporte para
						múltiples usuarios.
					</p>
					<div class="portfolio-card__tags">
						<span>React</span><span>TypeScript</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
		</div>
	</section>

	<!-- ESTADISTICAS -->
	<section id="estadisticas" class="estadisticas">
		<h2>En números</h2>
		<div class="stats__grid">
			<div class="stat-card">
				<span class="stat-number" data-target="35">0</span>
				<span class="stat-label">Proyectos completados</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="35">0</span>
				<span class="stat-label">Proyectos completados</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="20">0</span>
				<span class="stat-label">Proyectos completados</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="20">0</span>
				<span class="stat-label">Clientes satisfechos</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="5">0</span>
				<span class="stat-label">Años de experiencia</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="99">0</span>
				<span class="stat-label">Tazas de café ☕</span>
			</div>
		</div>
	</section>

	<!-- TESTIMONIOS -->
</Layout>
