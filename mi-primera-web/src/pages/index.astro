---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mi Primera Web con Astro">
	<!-- HERO -->
	<section class="hero">
		<h1>Bienvenido a Mi Página</h1>
		<p>Construida con Astro, paso a paso.</p>
		<a href="#sobre-mi" class="btn">Descúbreme</a>
	</section>

	<!-- SOBRE MÍ -->
	<section id="sobre-mi" class="sobre-mi">
		<div class="sobre-mi__inner">
			<div class="sobre-mi__avatar">
				<div class="avatar-placeholder">👤</div>
			</div>
			<div class="sobre-mi__content">
				<h2>Sobre mí</h2>
				<p>
					Soy un desarrollador apasinado por crear experiencias web
					únicas y de alto rendimiento.
				</p>
				<p>
					Cuando no estoy programando, estoy explorando nuevas
					tecnologías o tomando café ☕.
				</p>
				<div class="skills">
					<span class="skill-tag">Astro</span>
					<span class="skill-tag">React</span>
					<span class="skill-tag">Typescript</span>
					<span class="skill-tag">Node.js</span>
					<span class="skill-tag">CSS</span>
					<span class="skill-tag">Git</span>
				</div>
			</div>
		</div>
	</section>

	<!-- PORTFOLIO -->
	<section id="portfolio" class="portfolio">
		<h2>Portfolio</h2>
		<p class="section-subtitle">Algunos de mis proyectos recientes</p>
		<div class="portfolio__grid">
			<article class="portfolio-card">
				<div class="portfolio-card__img">🌐</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Alpha</h3>
					<p>
						Aplicación web construida con Astro y React. Optimizada
						para velocidad y SEO.
					</p>
					<div class="portfolio-card__tags">
						<span>Astro</span><span>React</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
			<article class="portfolio-card">
				<div class="portfolio-card__img">⚡</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Beta</h3>
					<p>
						Dashborad interactivo con visualización de datos en
						tiempo real.
					</p>
					<div class="portfolio-card__tags">
						<span>TypeScript</span><span>Node.js</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
			<article class="portfolio-card">
				<div class="portfolio-card__img">🚀</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Gamma</h3>
					<p>
						E-commerce moderno con integración de pagos y gestión de
						inventario.
					</p>
					<div class="portfolio-card__tags">
						<span>CSS</span><span>Git</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
			<article class="portfolio-card">
				<div class="portfolio-card__img">🎨</div>
				<div class="portfolio-card__body">
					<h3>Proyecto Delta</h3>
					<p>
						Plataforma de diseño colaborativo con soporte para
						múltiples usuarios.
					</p>
					<div class="portfolio-card__tags">
						<span>React</span><span>TypeScript</span>
					</div>
					<a href="#" class="btn btn--sm">Ver proyecto →</a>
				</div>
			</article>
		</div>
	</section>

	<!-- ESTADISTICAS -->
	<section id="estadisticas" class="estadisticas">
		<h2>En números</h2>
		<div class="stats__grid">
			<div class="stat-card">
				<span class="stat-number" data-target="35">0</span>
				<span class="stat-label">Proyectos completados</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="20">0</span>
				<span class="stat-label">Clientes satisfechos</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="5">0</span>
				<span class="stat-label">Años de experiencia</span>
			</div>
			<div class="stat-card">
				<span class="stat-number" data-target="99">0</span>
				<span class="stat-label">Tazas de café ☕</span>
			</div>
		</div>
	</section>

	<!-- TESTIMONIOS -->
	 <section id="testimonios" class="testimonios">
		<h2>Testimonios</h2>
		<p class="section-subtitle">Lo que dicen quienes han trabajado conmigo</p>
		<div class="testimonios__grid">
			<blockquote class="testimonio-card">
				<p>"Excelente trabajo, entregó el proyecto a tiempo con una calidad impresionante."</p>
				<footer>
					<strong>Ana García</strong>
					<span>Ceo de StartupXYZ</span>
				</footer>
			</blockquote>
			<blockquote class="testimonio-card">
				<p>"Muy profesional y detallista. El resultado superó todas nuestras expectativas."</p>
				<footer>
					<strong>Carlos Méndez</strong>
					<span>Director Creativo</span>
				</footer>
			</blockquote>
			<blockquote class="testimonio-card">
				<p>"Comunicación clara y código limpio. Sin duda volverémos a trabajar juntos."</p>
				<footer>
					<strong>Laura Torres</strong>
					<span>Product Manager</span>
				</footer>
			</blockquote>
		</div>
	</section>

	<!-- FAQ -->
	<section id="faq" class="faq">
		<h2>Preguntas frecuentes</h2>
		<p class="section-subtitle">Todo lo que necesitas saber</p>
		<div class="faq__list">
			<details class="faq-item">
				<summary>¿Con qué tecnologías trabajas?</summary>
				<p>Trabajo principalmente con Astro, React, TypeScript, Node.js y CSS moderno.</p>
			</details>
			<details class="faq-item">
				<summary>¿Cuánto tiempo tarda un proyecto?</summary>
				<p>Un sitio web puede estar listo en 1-2 semanas. Una app compleja puede tardar 1-3 meses.</p>
			</details>
			<details class="faq-item">
				<summary>¿Ofreces mantenimiento después de la entrega?</summary>
				<p>Sí, ofrezco planes de mantenimiento mensual con actualizaciones y soporte técnico.</p>
			</details>
			<details class="faq-item">
				<summary>¿Cómo es el proceso de trabajo?</summary>
				<p>Reunión de descubrimiento → prototipo → desarrollo → pruebas → entrega final.</p>
			</details>
			<details class="faq-item">
				<summary>¿Trabajas con clientes internacionales?</summary>
				<p>Sí, trabajo de forma remota. Me comunico en español e inglés</p>
			</details>
		</div>
	</section>
	
	<!-- Servicios -->
	 <section id="servicios" class="servicios">
		<h2>Servicios</h2>
		<ul>
			<li>🌐 Desarrollo Web</li>
			<li>⚡ Aplicaciones rápidas</li>
			<li>📄 Documentación clara</li>
		</ul>
	</section>

	<!-- CONTACTO -->
	 <section id="contacto" class="contacto">
		<h2>Contacto</h2>
		<form>
			<input type="text" placeholder="Tu nombre" required />
			<input type="email" placeholder="Tu correo" required />
			<textarea placeholder="Tu mensaje"></textarea>
			<button type="submit">Enviar</button>
		</form>
	</section>

	<script>
		const counters = document.querySelectorAll('.stat-number');
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const el = entry.target;
					const target = parseInt(el.dataset.target ?? '0', 10);
					let current = 0;
					const step = Math.ceil(target / 60);
					const timer = setInterval(() => {
						current += step;
						if (current >= target) {
							el.textContent = String(target);
							clearInterval(timer);
						} else {
							el.textContent = String(current);
						}
					}, 30);
					observer.unobserve(el);
				}
			});
		}, { threshold: 0.5 });
		counters.forEach(c => observer.observe(c));
	</script>
</Layout>
